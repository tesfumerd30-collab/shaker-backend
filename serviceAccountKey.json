const express = require('express');
const admin = require('firebase-admin');
const cors = require('cors');

const app = express();
app.use(cors());
app.use(express.json());

// የ Firebase Admin SDK ማዋቀሪያ
// ይህ ኮድ የሰቀልከውን serviceAccountKey.json ፋይል በራስ-ሰር ይጠቀማል
const serviceAccount = require('./serviceAccountKey.json');

admin.initializeApp({
  credential: admin.credential.cert(serviceAccount),
  databaseURL: "https://tesfuweb-default-rtdb.firebaseio.com"
});

const db = admin.database();

// ተጫዋቾችን ለመመዝገብ የሚጠቅም መንገድ (Endpoint)
app.post('/add-player', (req, res) => {
    const { roomId, userId, name, phone } = req.body;
    
    // መረጃውን Firebase ውስጥ ማስቀመጥ
    db.ref(`rooms/${roomId}/${userId}`).set({
        name: name,
        phone: phone,
        paid: false
    })
    .then(() => {
        res.status(200).send({ success: true, message: "ተጫዋች ተመዝግቧል" });
    })
    .catch((error) => {
        res.status(500).send({ success: false, error: error.message });
    });
});

const PORT = process.env.PORT || 3000;
app.listen(PORT, () => {
    console.log(`ሰርቨሩ በፖርት ${PORT} እየሰራ ነው`);
});
